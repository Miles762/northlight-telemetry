# Optional local overrides. The app runs without this file because each component
# has localhost defaults; copy/export only when you need to change ports or hosts.

# Backend API -> PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/northlight

# Dashboard -> backend API
VITE_API_URL=http://127.0.0.1:8000

# macOS agent -> backend API
NORTHLIGHT_BACKEND_URL=http://127.0.0.1:8000

# Synthetic generator -> backend API
BACKEND_URL=http://127.0.0.1:8000
